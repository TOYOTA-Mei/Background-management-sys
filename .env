# Django项目环境配置文件

# ==================== 核心配置 ====================
# Django密钥（生产环境务必修改）
SECRET_KEY=django-insecure-change-this-to-a-random-secret-key

# 调试模式（生产环境设为 False）
DEBUG=True

# 允许的主机（用逗号分隔）
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== 数据库配置 ====================
# 数据库引擎（mysql 或 sqlite3）
DB_ENGINE=mysql

# MySQL数据库配置
DB_NAME=db_admin
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306

# SQLite配置（如果使用SQLite，注释掉上面的MySQL配置）
# DB_ENGINE=sqlite3
# DB_NAME=db.sqlite3

# ==================== JWT配置 ====================
# JWT密钥（可选，如需自定义）
# JWT_SECRET_KEY=your-jwt-secret-key

# Token过期时间（秒），默认7天
# JWT_EXPIRATION_DELTA=604800

# ==================== 媒体文件配置 ====================
# 媒体文件存储路径
MEDIA_ROOT=media

# 媒体文件访问URL
MEDIA_URL=media/

# ==================== 缓存配置 ====================
# 缓存过期时间（秒），默认1小时
CACHE_TIMEOUT=3600
